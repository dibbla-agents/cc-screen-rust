# public/ is built from ../docs at deploy time (see deploy.sh).
/public/
/target/
/Cargo.lock
# scratch screenshots used to author the site assets — not part of the repo.
/tmp-images/
# Hosted release assets (installers + binaries) served at /dl. Generated by
# release-host.sh from the CI build artifacts — large + regenerated per release,
# so not committed. The dir itself is kept (the Dockerfile COPYs it).
/dl/*
!/dl/.gitkeep
