# Local multi-tenant dev for cc-screen-hub (proposal 0001). Copy to `.env` (which
# is gitignored) and fill in real values. Load with:  set -a; . ./.env; set +a
# Multi-tenant requires a build with `--features multi-tenant`.

# Database URL → enables multi-tenant mode. SQLite first (Postgres backend later).
CCHUB_DATABASE_URL=sqlite:///var/lib/cc-screen-hub/hub.db

# Google "Sign in with Google" (Authorization Code + PKCE, exchanged server-side).
# Create OAuth credentials in the Google Cloud console and register the redirect
# URI  <CCHUB_PUBLIC_URL>/api/auth/google/callback.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# Public origin the hub builds redirect/verification URIs against (no trailing /).
CCHUB_PUBLIC_URL=http://localhost:8840
