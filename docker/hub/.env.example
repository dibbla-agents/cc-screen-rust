# Copy to `.env` and fill in. Every var is OPTIONAL — with all blank the hub runs
# with NO auth and an OPEN agent uplink (fine on a private tailnet, NOT for a
# public / proxied hub). Generate a token with:  openssl rand -hex 32

# ── Client auth gate (browser PWA + `ccs` TUI) ───────────────────────────────
# Set at least one to require a credential on every /api/ request.
#   CCWEB_API_TOKEN — the "API key": headless clients send it as
#                     `Authorization: Bearer <token>`; the web login accepts it too.
#   CCWEB_PASSWORD  — a web-login password (mints a 2-week cookie). Optional; the
#                     token alone is enough.
CCWEB_API_TOKEN=
CCWEB_PASSWORD=

# ── Per-agent uplink tokens (who may register as a machine) ───────────────────
# Comma-separated `machine:token` pairs. Empty = OPEN uplink (any agent may
# register). Set it so only known machines can join. This is a SEPARATE secret
# from the client gate above — a leaked client token can't impersonate an agent.
#
# Each machine host then dials in with:
#   cc-screen-rust ... --hub http://HUB:8840 --token <token> --machine-id <machine>
#
# Example (uncomment + edit):
# CCHUB_AGENT_TOKENS=pine:CHANGE-ME-pine,oak:CHANGE-ME-oak
CCHUB_AGENT_TOKENS=
