# Copy to `.env` and fill in. All optional, but set a machine id and either creds
# or mounted login dirs, plus a hub uplink (recommended) or a client gate.

# ── Identity ─────────────────────────────────────────────────────────────────
# This agent's name in the hub's machine list / the TUI machine picker.
CCWEB_MACHINE_ID=docker-agent

# ── Assistant credentials ────────────────────────────────────────────────────
# Per CLI you actually use. Two ways to authenticate (pick one per CLI):
#   1) Pass an API key here (simplest, non-interactive), OR
#   2) Leave blank and mount the CLI's login dir under the home volume — i.e. run
#      `claude` / `codex` / `gemini` once inside the container to log in; the creds
#      land in ./home/.claude, ./home/.codex, ./home/.gemini and persist.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=

# ── Hub uplink (recommended topology) ────────────────────────────────────────
# Dial OUT to your hub so this YOLO box accepts no inbound. Point at the hub's
# reachable address; the token must match its CCHUB_AGENT_TOKENS entry for this
# machine. Then set CCWEB_HUB_ONLY=1 and keep the compose `ports:` commented.
CCWEB_HUB_URL=
CCWEB_HUB_TOKEN=
# CCWEB_HUB_ONLY=1

# ── Client auth gate (standalone mode) ───────────────────────────────────────
# Only relevant if you expose :8839 directly (no hub). Gates direct connections;
# headless clients send `Authorization: Bearer <token>`. Generate: openssl rand -hex 32
# NB: the agent's fail-closed guard refuses a routable bind with neither set, so
# binding off-loopback requires a credential here. If you front it with a TLS proxy
# on a custom domain, also set CCWEB_ALLOWED_ORIGINS so the browser Origin check passes.
CCWEB_API_TOKEN=
CCWEB_PASSWORD=
# CCWEB_ALLOWED_ORIGINS=
